# Copy this file to .env.local and fill in your values.
# Never commit .env.local — it contains secrets.

# Supabase project URL and public anon key (safe to expose in browser)
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_...

# Service role key — server-side only, never in NEXT_PUBLIC_* or client bundle
SUPABASE_SERVICE_ROLE_KEY=sb_secret_...

# Direct Postgres pooler connection string — server-side only
DATABASE_URL=postgresql://postgres.xxxx:PASSWORD@aws-1-us-west-2.pooler.supabase.com:5432/postgres

# Anthropic API key — server-side only, used for AI targeting
ANTHROPIC_API_KEY=sk-ant-...
